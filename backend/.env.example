# ============================================
# Judge0 API Configuration
# ============================================

# Provider: "rapid" or "self-hosted"
JUDGE0_PROVIDER=rapid

# RapidAPI Key (required when JUDGE0_PROVIDER=rapid)
# Get yours at: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_RAPID_API_KEY=your-rapidapi-key-here

# Self-hosted URL (required when JUDGE0_PROVIDER=self-hosted)
# JUDGE0_BASE_URL=http://localhost:2358

# ============================================
# Resource Limits
# ============================================
JUDGE0_CPU_LIMIT=5
JUDGE0_MEMORY_LIMIT=128000

# ============================================
# Flask Configuration
# ============================================
FLASK_SECRET_KEY=change-this-in-production
